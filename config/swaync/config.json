{
  "$schema": "/etc/xdg/swaync/configSchema.json",

  "positionX": "right",
  "positionY": "top",

  "control-center-positionX": "right",
  "control-center-positionY": "top",

  "layer": "overlay",
  "control-center-layer": "overlay",

  "control-center-width": 400,
  "control-center-height": 430,

  "control-center-margin-top": 54,
  "control-center-margin-bottom": 12,
  "control-center-margin-right": 16,
  "control-center-margin-left": 12,

  "notification-window-width": 390,

  "notification-icon-size": 42,
  "notification-body-image-height": 120,
  "notification-body-image-width": 240,

  "timeout": 7,
  "timeout-low": 4,
  "timeout-critical": 0,

  "fit-to-screen": true,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 180,

  "hide-on-clear": false,
  "hide-on-action": true,
  "script-fail-notify": true,

  "widgets": [
    "title",
    "dnd",
    "notifications"
  ],

  "widget-config": {
    "title": {
      "text": "notifications",
      "clear-all-button": true,
      "button-text": "clear"
    },

    "dnd": {
      "text": "do not disturb"
    }
  }
}
